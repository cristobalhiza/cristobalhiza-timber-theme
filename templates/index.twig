{% extends "base.twig" %}

{% block content %}
    <div class="bg-white p-8 rounded-lg shadow-md text-center max-w-2xl mx-auto" x-data="{ open: false }">
        <h1 class="text-4xl font-bold text-blue-600 mb-4">¡Arquitectura Modular Completada!</h1>
        <p class="text-gray-700 mb-6 text-lg">
            Esta vista hija está inyectando su contenido dentro del Layout maestro de forma dinámica.
        </p>
        
        <button 
            @click="open = !open" 
            class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-6 rounded-lg transition duration-300 shadow"
        >
            <span x-text="open ? 'Ocultar Mensaje' : 'Mostrar Mensaje'"></span>
        </button>

        <div x-show="open" x-transition class="mt-6 p-4 bg-green-50 border border-green-200 text-green-800 rounded-lg">
            Alpine.js y Tailwind CSS compilado están operando en perfecta armonía.
        </div>
    </div>
{% endblock %}